# ── Local Development ──────────────────────────────────────────
# Leave DATABASE_URL unset to use local SQLite (db/hrp.db)
PORT=3000

# ── Production (Vercel + Neon PostgreSQL) ──────────────────────
# Get this from: https://console.neon.tech → your project → Connection Details
# Use the "Pooled connection" string (ends with ?sslmode=require)
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Auth ───────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=10

# ── Source HTML (seed script only, not needed on Vercel) ───────
SOURCE_HTML=D:/mch tracker/index.html
